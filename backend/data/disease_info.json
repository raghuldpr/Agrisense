      "ta": "தாமத காய்ச்சல்"
    },
    "risk_level": "high",
    "symptoms": {
      "en": "Water-soaked lesions turning brown-black, white mold on leaf underside",
      "hi": "पानी से भीगे घाव जो भूरे-काले हो जाते हैं, पत्ती के नीचे सफेद फफूंद",
      "ta": "நீர் தோய்ந்த புண்கள் பழுப்பு-கருப்பாக மாறும், இலையின் கீழ் வெள்ளை பூஞ்சை"
    },
    "treatment": {
      "en": [
        "Spray Metalaxyl + Mancozeb (Ridomil Gold) @ 2.5g/litre",
        "Remove heavily infected plants",
        "Apply Cymoxanil 8% + Mancozeb 64% WP"
      ],
      "hi": [
        "Metalaxyl + Mancozeb (Ridomil Gold) @ 2.5g/लीटर का छिड़काव करें",
        "अधिक संक्रमित पौधों को हटा दें",
        "Cymoxanil 8% + Mancozeb 64% WP लगाएं"
      ],
      "ta": [
        "Metalaxyl + Mancozeb (Ridomil Gold) @ 2.5கி/லி தெளிக்கவும்",
        "அதிகமாக பாதிக்கப்பட்ட செடிகளை அகற்றவும்",
        "Cymoxanil 8% + Mancozeb 64% WP தெளிக்கவும்"
      ]
    },
    "prevention": {
      "en": [
        "Use certified disease-free seeds",
        "Avoid wet foliage — water at base only",
        "Apply preventive fungicide spray during humid weather"
      ],
      "hi": [
        "प्रमाणित रोगमुक्त बीजों का उपयोग करें",
        "पत्तियों को गीला न करें — केवल जड़ में पानी दें",
        "नम मौसम में निवारक फफूंदनाशक का छिड़काव करें"
      ],
      "ta": [
        "சான்றளிக்கப்பட்ட நோயற்ற விதைகளை பயன்படுத்தவும்",
        "இலைகளை நனைக்காதீர்கள் — அடியில் மட்டும் நீர் ஊற்றவும்",
        "ஈரமான வானிலையில் தடுப்பு பூஞ்சைக்கொல்லி தெளிக்கவும்"
      ]
    },
    "weather_risk": {
      "humidity_above": 90,
      "temp_min": 10,
      "temp_max": 25
    }
  },
