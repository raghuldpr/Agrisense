{
  "Tomato_Early_Blight": {
    "crop": {
      "en": "Tomato",
      "hi": "टमाटर",
      "ta": "தக்காளி"
    },
    "disease": {
      "en": "Early Blight",
      "hi": "अर्ली ब्लाइट",
      "ta": "ஆரம்ப காய்ச்சல்"
    },
    "risk_level": "medium",
    "symptoms": {
      "en": "Dark brown spots with concentric rings on older leaves",
      "hi": "पुरानी पत्तियों पर गहरे भूरे रंग के केंद्रित छल्लेदार धब्बे",
      "ta": "பழைய இலைகளில் கருமையான வளையங்களுடன் கூடிய பழுப்பு புள்ளிகள்"
    },
    "treatment": {
      "en": [
        "Apply copper-based fungicide (Blitox 50 WP)",
        "Remove and destroy infected leaves immediately",
        "Apply Mancozeb 75 WP @ 2g per litre of water"
      ],
      "hi": [
        "कॉपर आधारित फफूंदनाशक (Blitox 50 WP) का छिड़काव करें",
        "संक्रमित पत्तियों को तुरंत हटाएं और नष्ट करें",
        "Mancozeb 75 WP @ 2g प्रति लीटर पानी में डालकर छिड़काव करें"
      ],
      "ta": [
        "செம்பு அடிப்படையிலான பூஞ்சைக்கொல்லி (Blitox 50 WP) தெளிக்கவும்",
        "பாதிக்கப்பட்ட இலைகளை உடனே அகற்றி அழிக்கவும்",
        "Mancozeb 75 WP @ 2கி/லி தண்ணீரில் கலந்து தெளிக்கவும்"
      ]
    },
    "prevention": {
      "en": [
        "Avoid overhead irrigation",
        "Maintain proper plant spacing for airflow",
        "Rotate crops every season"
      ],
      "hi": [
        "ऊपर से सिंचाई से बचें",
        "वायु प्रवाह के लिए पौधों के बीच उचित दूरी बनाए रखें",
        "हर मौसम में फसल चक्र अपनाएं"
      ],
      "ta": [
        "மேலிருந்து நீர்ப்பாசனம் தவிர்க்கவும்",
        "காற்று சரியாக வர போதுமான இடைவெளி விடவும்",
        "ஒவ்வொரு பருவமும் பயிர் சுழற்சி பின்பற்றவும்"
      ]
    },
    "weather_risk": {
      "humidity_above": 80,
      "temp_min": 24,
      "temp_max": 29
    }
  },
  "Tomato_Late_Blight": {
    "crop": {
      "en": "Tomato",
      "hi": "टमाटर",
      "ta": "தக்காளி"
    },
    "disease": {
      "en": "Late Blight",
